pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "gangadhara2010/cloud-app"
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main', url: 'https://github.com/rayudu-gangadhara-rao/cloud-app.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t cloud-app .'
            }
        }

        stage('Tag Image') {
            steps {
                sh 'docker tag cloud-app $DOCKER_IMAGE:latest'
            }
        }

        stage('Push to Docker Hub') {
            steps {
                sh 'docker push $DOCKER_IMAGE:latest'
            }
        }
    }
}